local function createButton(name, callback, parent, layoutOrder, isSmall)
    local target = parent or ButtonsContainer
    local row = Instance.new("Frame", target)
    row.Name = name
    row.Size = isSmall and UDim2.new(1, -10, 0, 28) or UDim2.new(1, -8, 0, 38)
    row.BackgroundTransparency = isSmall and 0.8 or 1
    row.BackgroundColor3 = isSmall and Color3.new(0, 0, 0) or Color3.fromRGB(255, 80, 80)
    row.ZIndex = 15
    row.LayoutOrder = layoutOrder or 0
    local rowCorner = Instance.new("UICorner", row)
    rowCorner.CornerRadius = UDim.new(0, 6)
    local rowStroke = Instance.new("UIStroke", row)
    rowStroke.Color = isSmall and Color3.new(1, 1, 1) or Color3.fromRGB(255, 80, 80)
    rowStroke.Thickness = isSmall and 1 or 1.2
    rowStroke.Transparency = isSmall and 0.5 or 0
    local btn = Instance.new("TextButton", row)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = name
    btn.TextColor3 = isSmall and Color3.new(1, 1, 1) or Color3.fromRGB(255, 80, 80)
    btn.TextTransparency = isSmall and 0.5 or 0
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = isSmall and 12 or 14
    btn.ZIndex = 16
    btn.MouseButton1Click:Connect(function()
        if not isSmall then
            row.BackgroundTransparency = 0.7
            row.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
            TweenService:Create(row, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
        end
        callback(btn)
    end)
    return row
end

