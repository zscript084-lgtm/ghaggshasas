local function createToggle(name, layoutOrder, callback)
    local row = Instance.new("Frame", ButtonsContainer)
    row.Size = UDim2.new(1, -5, 0, 38)
    row.BackgroundTransparency = 1
    row.LayoutOrder = layoutOrder or 0
    row.ZIndex = 11
    
    local rStroke = Instance.new("UIStroke", row)
    rStroke.Color = Color3.fromRGB(255, 80, 80)
    rStroke.Thickness = 1.2
    rStroke.Transparency = 0.2

    local rCorner = Instance.new("UICorner", row)
    rCorner.CornerRadius = UDim.new(0, 8)

    local btn = Instance.new("TextButton", row)
    btn.Size = UDim2.new(1, -50, 1, 0)
    btn.Position = UDim2.new(0, 10, 0, 0)
    btn.BackgroundTransparency = 1
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(255, 80, 80)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 13
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.ZIndex = 12

    local toggleFrame = Instance.new("Frame", row)
    toggleFrame.Size = UDim2.new(0, 34, 0, 18)
    toggleFrame.Position = UDim2.new(1, -44, 0.5, -9)
    toggleFrame.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    toggleFrame.BackgroundTransparency = 0.5
    toggleFrame.ZIndex = 12
    Instance.new("UICorner", toggleFrame).CornerRadius = UDim.new(1, 0)

    local circle = Instance.new("Frame", toggleFrame)
    circle.Size = UDim2.new(0, 14, 0, 14)
    circle.Position = UDim2.new(0, 2, 0.5, -7)
    circle.BackgroundColor3 = Color3.new(1, 1, 1)
    circle.ZIndex = 13
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)

    local state = false
    local function update(v)
        state = v
        TweenService:Create(toggleFrame, TweenInfo.new(0.2), {BackgroundColor3 = state and Color3.fromRGB(255, 80, 80) or Color3.fromRGB(50, 50, 50)}):Play()
        TweenService:Create(circle, TweenInfo.new(0.2), {Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)}):Play()
        callback(state)
    end

    btn.MouseButton1Click:Connect(function() update(not state) end)
end

local function addButtons()
